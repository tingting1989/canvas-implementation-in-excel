{
    "source": {
        "include": ["src"],
        "exclude": ["src/**/*.test.js", "node_modules"],
        "includePattern": ".+\\.js$"
    },
    "opts": {
        "destination": "./api-docs",
        "recurse": true,
        "readme": "README.md"
    },
    "plugins": ["plugins/markdown"],
    "templates": {
        "cleverLinks": true,
        "monospaceLinks": true
    }
}