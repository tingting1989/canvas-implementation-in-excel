{
    "name": "@canvas-sheet/core",
    "version": "1.0.3",
    "description": "Canvas-based spreadsheet engine with Web Components UI",
    "main": "dist/canvas-sheet.umd.js",
    "module": "dist/canvas-sheet.esm.mjs",
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "dev": "webpack serve --mode development",
        "build": "webpack --mode production",
        "build:lib": "webpack --config webpack.lib.config.js",
        "lint": "npm run lint:js",
        "lint:js": "eslint . --fix",
        "format": "prettier --write src/",
        "lint-staged": "lint-staged",
        "prepare": "husky",
        "pre-commit": "lint-staged",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage",
        "prepublishOnly": "npm run build:lib",
        "publish:lib": "npm publish --registry http://10.124.26.35:4873/",
        "unpublish": "npm unpublish @canvas-sheet/core --registry http://10.124.26.35:4873/ --force",
        "push": "git push origin",
        "push:all": "git push origin && git push internal",
        "push:origin": "git push origin",
        "push:internal": "git push internal",
        "pull": "git pull origin",
        "pull:origin": "git pull origin",
        "pull:internal": "git pull internal",
        "remote:list": "git remote -v"
    },
    "publishConfig": {
        "registry": "http://10.124.26.35:4873/"
    },
    "keywords": [
        "canvas",
        "spreadsheet",
        "excel",
        "web-components"
    ],
    "author": "jiangsuiting",
    "license": "UNLICENSED",
    "lint-staged": {
        "*.{js,mjs}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md}": [
            "prettier --write"
        ]
    },
    "devDependencies": {
        "@babel/core": "^8.0.1",
        "@babel/preset-env": "^8.0.2",
        "@eslint/js": "^10.0.1",
        "@vitest/ui": "^4.1.9",
        "@vue/eslint-config-prettier": "^10.2.0",
        "babel-loader": "^10.1.1",
        "css-loader": "^7.1.4",
        "eslint": "^10.4.1",
        "eslint-plugin-import-x": "^4.12.2",
        "eslint-plugin-vue": "^10.8.0",
        "globals": "^16.0.0",
        "html-webpack-plugin": "^5.6.0",
        "husky": "^9.0.11",
        "jsdom": "^29.1.1",
        "lint-staged": "^16.4.0",
        "prettier": "^3.0.3",
        "style-loader": "^4.0.0",
        "terser-webpack-plugin": "^5.6.1",
        "vitest": "^4.1.9",
        "webpack": "^5.90.3",
        "webpack-cli": "^7.0.3",
        "webpack-dev-server": "^5.0.2"
    }
}
